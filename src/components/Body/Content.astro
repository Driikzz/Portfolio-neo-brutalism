---
import HeaderService from "./Services/HeaderService";
import CardService from "./Services/CardService";
import Projects from "./Projects/Projects.astro";
import TimelineDiscussions from "./Timeline/TimelineDiscussions.astro";
import Footer from "../Footer";
---

<div>
  <section id="services">
  <HeaderService client:load />
  <div class="servicesGrid">
    <CardService icon="code" title="Frontend" description="Des interfaces rapides et maintenables avec React et TypeScript. Composants réutilisables, state management propre, DX au top." iconBg="#8C52FF" iconShape="rounded" />
    <CardService icon="smartphone" title="Mobile" description="Applications iOS et Android avec React Native. Une seule codebase TypeScript, une expérience native sur les deux plateformes." iconBg="#22D3EE" iconShape="circle" />
    <CardService icon="layers" title="Full Stack" description="Du front au back, je maîtrise toute la chaîne : React, Node.js, bases de données et déploiement cloud. Un seul interlocuteur, pas de prise de tête." iconBg="#FF3EA5" iconShape="tag" />
  </div>
  </section>

  <Projects />
  <TimelineDiscussions />
  <Footer />
</div>

<style>
  .servicesGrid {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
    padding: 20px;
  }

  @media (max-width: 768px) {
    .servicesGrid {
      flex-direction: column;
      padding: 16px;
      align-items: stretch;
    }
  }
</style>